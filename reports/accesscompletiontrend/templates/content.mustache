{{!
    @template gimidashboardreports_accesscompletiontrend/content

    Example context (json):
    {
    }
}}


<div class="gimi-accesscompletiontrend">
    <div class="gimi-accesscompletiontrend-summary gimi-kpi-grid"
    style="grid-template-columns: repeat(4, minmax(0, 1fr));">
        {{#summarycards}}
            <div class="gimi-kpi-card">
                <div class="gimi-kpi-card-label">{{{label}}}</div>
                <div class="gimi-kpi-card-value">{{{value}}}</div>
            </div>
        {{/summarycards}}
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                <div>
                    <h6 class="fw-semibold mb-1">{{#str}}
                        pluginname, gimidashboardreports_accesscompletiontrend{{/str}}</h6>
                    <div class="text-muted">{{{charthelp}}}</div>
                </div>
                <div class="gimi-accesscompletiontrend-legend">
                    {{#chartlegend}}
                        <span class="gimi-accesscompletiontrend-legend-item">
                            <span class="gimi-accesscompletiontrend-legend-dot" style="background:{{{color}}}"></span>
                            {{{label}}}
                        </span>
                    {{/chartlegend}}
                </div>
            </div>
            <div class="gimi-accesscompletiontrend-chart">{{{chartsvg}}}</div>
        </div>
    </div>

    {{#hasrows}}
        {{{tablehtml}}}
    {{/hasrows}}

    {{^hasrows}}
        <div class="alert alert-light">{{{emptylabel}}}</div>
    {{/hasrows}}
</div>
<link rel="stylesheet" href="/local/gimidashboard/reports/accesscompletiontrend/styles.css">
