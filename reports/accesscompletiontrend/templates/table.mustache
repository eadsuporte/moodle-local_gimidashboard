{{!
    @template gimidashboardreports_accesscompletiontrend/table

    Example context (json):
    {
    }
}}


<div style="width:100%;overflow-x:auto;">
    <table id="accesscompletiontrend-table" class="table table-bordered"
           data-title="Course access and completion trend">
        <thead>
        <tr>
            {{#headers}}
                <th class="text-nowrap">{{{label}}}</th>
            {{/headers}}
        </tr>
        </thead>
        <tbody>
        {{#hasrows}}
            {{#rows}}
                <tr>
                    <td><a href="{{{courseurl}}}"target="_blank" class="text-nowrap">{{{course}}}</a></td>
                    <td class="text-center text-nowrap">{{{enrolled}}}</td>
                    <td class="text-center text-nowrap">{{{accesses}}}</td>
                    <td class="text-center text-nowrap">{{{userswithaccess}}}</td>
                    <td class="text-center text-nowrap">{{{completions}}}</td>
                    <td class="text-center text-nowrap">{{{completionrate}}}</td>
                    <td class="text-center text-nowrap">{{{lastaccess}}}</td>
                </tr>
            {{/rows}}
        {{/hasrows}}

        {{^hasrows}}
            <tr>
                <td colspan="7">{{{emptymessage}}}</td>
            </tr>
        {{/hasrows}}
        </tbody>
    </table>
</div>
