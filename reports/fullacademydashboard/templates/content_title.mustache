{{!
    @template gimidashboardreports_fullacademydashboard/content-title

    Example context (json):
    {
    }
}}

<div class="gimi-full-dashboard-header">
    <div class="gimi-full-dashboard-header-main d-flex justify-content-between align-items-start gap-3">
        <div style="width:100%">
            <h3>{{{academyname}}} <span class="gimi-full-dashboard-plugin-name">- {{{pluginname}}}</span></h3>
            <div class="gimi-full-dashboard-header-sub">{{{subtitle}}}</div>
        </div>
        <div class="btn-group-vertical gap-2">
            <a href="{{{exporturl}}}" class="btn btn-success text-nowrap">
                {{#str}}exportexcel, gimidashboardreports_fullacademydashboard{{/str}}
            </a>
            {{{extra_html}}}
        </div>
    </div>
</div>
