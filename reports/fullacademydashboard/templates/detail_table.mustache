{{!
    @template gimidashboardreports_fullacademydashboard/detail_table

    Example context (json):
    {
    }
}}

<div style="width:100%;overflow-x:auto;">
    <table class="table table-bordered">
        <thead>
        <tr>
            {{#headers}}
                <th>{{{label}}}</th>
            {{/headers}}
        </tr>
        </thead>
        <tbody>
        {{#hasrows}}
            {{#rows}}
                <tr>
                    <td>{{{coursehtml}}}</td>
                    <td>{{{pathwayhtml}}}</td>
                    <td>{{{progress}}}</td>
                    <td>{{{grade}}}</td>
                    <td>{{{completed}}}</td>
                    <td>{{{exams}}}</td>
                    <td>{{{lastaccess}}}</td>
                    <td>{{{status}}}</td>
                </tr>
            {{/rows}}
        {{/hasrows}}

        {{^hasrows}}
            <tr>
                <td colspan="8">{{{emptymessage}}}</td>
            </tr>
        {{/hasrows}}
        </tbody>
    </table>
</div>