{{!
    @template gimidashboardreports_fullacademydashboard/summary_table

    Example context (json):
    {
    }
}}

<div style="width:100%;overflow-x:auto;">
    <table id="fullacademydashboard-summary_table" class="table table-bordered">
        <thead>
        <tr>
            {{#headers}}
                <th class="text-nowrap">{{{label}}}</th>
            {{/headers}}
        </tr>
        </thead>
        <tbody>
        {{#hasrows}}
            {{#rows}}
                <tr>
                    <td><a href="{{{learnerurl}}}">{{{firstname}}}</a></td>
                    <td><a href="{{{learnerurl}}}">{{{lastname}}}</a></td>
                    <td><a href="{{{learnerurl}}}">{{{email}}}</a></td>
                    <td class="text-center text-nowrap">{{{pathwayshtml}}}</td>
                    <td class="text-center text-nowrap">{{{courses}}}</td>
                    <td class="text-center text-nowrap">{{{avgprogress}}}</td>
                    <td class="text-center text-nowrap">{{{avggrade}}}</td>
                    <!--
                    <td class="text-center text-nowrap">{{{delta}}}</td>
                    -->
                    <td class="text-center text-nowrap">{{{completed}}}</td>
                    <td class="text-center text-nowrap">{{{certs}}}</td>
                    <td class="text-center text-nowrap">{{{exams}}}</td>
                    <td class="text-center text-nowrap">{{{lastaccess}}}</td>
                    <td class="text-center text-nowrap">{{{daysinactive}}}</td>
                    <td class="text-center text-nowrap">{{{status}}}</td>
                </tr>
            {{/rows}}
        {{/hasrows}}

        {{^hasrows}}
            <tr>
                <td colspan="14">{{{emptymessage}}}</td>
            </tr>
        {{/hasrows}}
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="/local/gimidashboard/reports/fullacademydashboard/styles.css">
