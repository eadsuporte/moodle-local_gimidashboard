{{!
    @template gimidashboardreports_leaderboard/content

    Example context (json):
    {
    }
}}
<div class="gimi-leaderboard-report">
    {{#hasmessage}}
        <div class="gimi-leaderboard-notice{{#messageiswarning}} is-warning{{/messageiswarning}}">
            {{{message}}}
        </div>
    {{/hasmessage}}

    {{#showpathwayoptions}}
        <div class="gimi-leaderboard-toolbar">
            <div class="gimi-toolbar-title">{{#str}}switchpathway, gimidashboardreports_leaderboard{{/str}}</div>
            <div class="gimi-toolbar-actions">
                {{#pathwayoptions}}
                    <a class="gimi-pathway-chip{{#selected}} is-active{{/selected}}" href="{{{url}}}">{{name}}</a>
                {{/pathwayoptions}}
                {{#hasclearpathway}}
                    <a class="gimi-pathway-chip is-clear" href="{{{clearpathwayurl}}}">{{#str}}resetpathway, gimidashboardreports_leaderboard{{/str}}</a>
                {{/hasclearpathway}}
            </div>
        </div>
    {{/showpathwayoptions}}

    {{#haskpis}}
        <div class="gimi-leaderboard-kpis gimi-kpi-grid" style="grid-template-columns: repeat(4, minmax(0, 1fr));">
            {{#kpis}}
                <div class="gimi-leaderboard-kpi gimi-kpi-card">
                    <div class="gimi-leaderboard-kpi-label gimi-kpi-card-label">{{label}}</div>
                    <div class="gimi-leaderboard-kpi-value gimi-kpi-card-value">{{value}}</div>
                </div>
            {{/kpis}}
        </div>
    {{/haskpis}}

    {{#hasboards}}
        <div class="gimi-leaderboard-grid">
            {{#boards}}
                <section class="gimi-leaderboard-card {{boardclass}}">
                    <div class="gimi-leaderboard-card-head">
                        <div>
                            <h4>{{title}}</h4>
                            <p>{{description}}</p>
                        </div>
                        <div class="gimi-leaderboard-badge">{{scopebadge}}</div>
                    </div>

                    {{#hasrows}}
                        <div class="table-responsive">
                            <table class="table table-sm gimi-leaderboard-table">
                                <thead>
                                <tr>
                                    <th>{{#str}}rank, gimidashboardreports_leaderboard{{/str}}</th>
                                    <th>{{#str}}learner, gimidashboardreports_leaderboard{{/str}}</th>
                                    <th>{{#str}}value, gimidashboardreports_leaderboard{{/str}}</th>
                                    <th>{{#str}}details, gimidashboardreports_leaderboard{{/str}}</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#rows}}
                                    <tr class="{{rowclass}}">
                                        <td>
                                            <span class="gimi-rank-pill {{rankclass}}">{{rankdisplay}}</span>
                                        </td>
                                        <td>
                                            <div class="gimi-learner-name">{{fullname}}</div>
                                            <div class="gimi-learner-email">{{email}}</div>
                                        </td>
                                        <td>
                                            <div class="gimi-metric-value">{{valuedisplay}}</div>
                                        </td>
                                        <td>
                                            <div class="gimi-metric-meta">{{details}}</div>
                                        </td>
                                    </tr>
                                {{/rows}}
                                </tbody>
                            </table>
                        </div>
                    {{/hasrows}}

                    {{^hasrows}}
                        <div class="gimi-empty-state">{{emptymessage}}</div>
                    {{/hasrows}}
                </section>
            {{/boards}}
        </div>
    {{/hasboards}}
</div>
<link rel="stylesheet" href="/local/gimidashboard/reports/leaderboard/styles.css">
