{{!
    @template local_gimidashboard/admin_plugins

    Example context (json):
    {
    }
}}

<div class="local-gimidashboard-admin py-3">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
            <div>
                <h4 class="mb-1">{{#str}}adminplugins, local_gimidashboard{{/str}}</h4>
                <div class="text-muted">{{{description}}}</div>
            </div>
            <div>
                <a class="btn btn-outline-primary" href="{{{dashboardurl}}}">{{{dashboardlabel}}}</a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <table class="flexible table table-striped table-hover generaltable table-sm">
                <tr>
                    <th class="header c0" scope="col">
                        {{#str}}position, local_gimidashboard{{/str}}
                    </th>
                    <th class="header c1" scope="col">
                        {{#str}}reportplugin, local_gimidashboard{{/str}}
                    </th>
                    <th class="header c2" scope="col">
                        {{#str}}status, local_gimidashboard{{/str}}
                    </th>
                    <th class="header c3" scope="col">
                        {{#str}}supports, local_gimidashboard{{/str}}
                    </th>
                    <th class="header c4" scope="col">
                        {{#str}}headercolor, local_gimidashboard{{/str}}
                    </th>
                    <th class="header c5" scope="col">
                        {{#str}}actions, local_gimidashboard{{/str}}
                    </th>
                </tr>
                {{#pluginsrows}}
                    <tr>
                        <td class="local-gimidashboard-admin-col-position">
                            {{{position}}}
                        </td>

                        <td class="local-gimidashboard-admin-col-plugin">
                            <div class="local-gimidashboard-admin-plugininfo">
                                <div class="local-gimidashboard-admin-pluginname">
                                    <a href="{{{previewurl}}}" title="{{{previewtitle}}}">
                                        {{{pluginname}}}
                                    </a>
                                </div>
                                <div class="local-gimidashboard-admin-component text-muted">
                                    <code>{{{component}}}</code>
                                </div>
                            </div>
                        </td>

                        <td class="local-gimidashboard-admin-col-status">
                    <span class="{{{statusbadgeclass}}}">
                        {{{statuslabel}}}
                    </span>
                        </td>

                        <td class="local-gimidashboard-admin-col-supports">
                            <div class="local-gimidashboard-admin-supports">
                                {{#supports}}
                                    <span class="{{{class}}}">{{{label}}}</span>
                                {{/supports}}
                                {{^supports}}
                                    <span class="text-muted">-</span>
                                {{/supports}}
                            </div>
                        </td>

                        <td class="local-gimidashboard-admin-col-color">
                            <form action="{{{savecolorurl}}}" method="post" class="local-gimidashboard-admin-colorform">
                                <input type="hidden" name="sesskey" value="{{{sesskey}}}">
                                <input type="hidden" name="action" value="saveheadercolor">
                                <input type="hidden" name="component" value="{{{component}}}">

                                <div class="local-gimidashboard-admin-colorwrap">
                                    <label>
                                        <input type="color"
                                               id="headercolor-{{{component}}}"
                                               name="basecolor"
                                               value="{{{basecolor}}}"
                                               class="form-control form-control-color">
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            {{{savecolorlabel}}}
                                        </button>
                                    </label>
                                    <div class="small text-muted">
                                        <code>{{{basecolor}}}</code> → <code>{{{accentcolor}}}</code>
                                    </div>
                                </div>
                            </form>
                        </td>

                        <td class="local-gimidashboard-admin-col-actions">
                            <div class="btn-group local-gimidashboard-admin-actions" role="group">
                                {{#canmoveup}}
                                    <a href="{{{moveupurl}}}" class="btn btn-sm btn-outline-secondary"
                                       title="{{{moveuplabel}}}">{{{moveupicon}}}</a>
                                {{/canmoveup}}
                                {{^canmoveup}}
                                    <span class="btn btn-sm btn-outline-secondary disabled">{{{moveupicon}}}</span>
                                {{/canmoveup}}

                                {{#canmovedown}}
                                    <a href="{{{movedownurl}}}" class="btn btn-sm btn-outline-secondary"
                                       title="{{{movedownlabel}}}">{{{movedownicon}}}</a>
                                {{/canmovedown}}
                                {{^canmovedown}}
                                    <span class="btn btn-sm btn-outline-secondary disabled">{{{movedownicon}}}</span>
                                {{/canmovedown}}

                                <a href="{{{toggleurl}}}" class="btn btn-sm btn-outline-primary"
                                   title="{{{togglelabel}}}">{{{toggleicon}}}</a>
                            </div>
                        </td>
                    </tr>
                {{/pluginsrows}}
            </table>


            {{{tablehtml}}}
        </div>
    </div>
</div>
