{{#isadmin}}
    <div class="gimidashboard-topbar">
        <a class="btn btn-primary gimidashboard-link" href="{{dashboardurl}}">Academy Dashboard</a>
        <a class="btn btn-primary gimidashboard-link" href="{{importurl}}">Bulk import</a>
    </div>

    {{{filter}}}

{{/isadmin}}

{{^isadmin}}
    {{#scope_label}}
        <div class="gimidashboard-scope">{{scope_label}}</div>
    {{/scope_label}}
{{/isadmin}}

{{#error}}
    <div class="gimidashboard-alert gimidashboard-alert-error">{{error}}</div>
{{/error}}

{{#success}}
    <div class="gimidashboard-alert gimidashboard-alert-success">
        <div><strong>{{success_title}}</strong></div>
        <div class="gimidashboard-success-line">
            Profile: <a href="{{profileurl}}" target="_blank" rel="noreferrer">{{userfullname}}</a>
        </div>

        <div class="gimidashboard-copylabel">WhatsApp message (copy & paste):</div>
        <pre class="gimidashboard-copy">{{whatsapptxt}}</pre>
    </div>
{{/success}}

{{#is_course_selected}}
    <div class="gimidashboard-panel">
        <div class="gimidashboard-panel-header">Add a learner to a cohort</div>
        <div class="gimidashboard-panel-body">

            <form method="post" action="{{actionurl}}">
                <input type="hidden" name="sesskey" id="sesskey" value="{{config.sesskey}}">

                <div class="gimidashboard-formrow">
                    <label for="fullname">Full name</label>
                    <input type="text" id="fullname" name="fullname" required>
                </div>

                <div class="gimidashboard-formrow">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="gimidashboard-formrow">
                    <label for="cohortid">Cohort</label>
                    <select id="cohortid" name="cohortid" required>
                        <option value="">Choose...</option>
                        {{#cohorts}}
                            <option value="{{id}}">{{name}}</option>
                        {{/cohorts}}
                    </select>
                </div>

                <div class="gimidashboard-formrow">
                    <button class="gimidashboard-btn" type="submit" name="submit" value="1">Enroll</button>
                </div>
            </form>

        </div>
    </div>
{{/is_course_selected}}
