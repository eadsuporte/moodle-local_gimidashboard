{{!
    @template local_gimidashboard/cohorts_tables

    Example context (json):
    {
        "message": "",
        "cohorts": [
            {
                "name": "Cohort A",
                "rows": [
                    {
                        "user_fullname": "Jhon Doe",
                        "email": "jdoe@example.com",
                        "course": "Math 101",
                        "group": "Group 1",
                        "progress": "85%",
                        "grade": "92",
                        "certificate_yes": true,
                        "certificate_no": false
                    },
                    {
                        "user_fullname": "Asmith Doe",
                        "email": "asmith@example.com",
                        "course": "Science 202",
                        "group": "Group 2",
                        "progress": "70%",
                        "grade": "88",
                        "certificate_yes": false,
                        "certificate_no": true
                    }
                ]
            },
            {
                "name": "Cohort B",
                "rows": []
            }
        ]
    }
}}

{{#message}}
    <div class="gimidashboard-empty">{{message}}</div>
{{/message}}

{{#cohorts}}
    <div class="gimidashboard-panel gimidashboard-cohort">
        <div class="gimidashboard-panel-header">{{name}}</div>

        <div class="gimidashboard-panel-body">
            <table class="gimidashboard-table" data-title="{{name}}">
                <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Course</th>
                    <th>Group</th>
                    <th>Progress</th>
                    <th>Grade</th>
                    <th>Certificate</th>
                </tr>
                </thead>
                <tbody>
                {{#rows}}
                    <tr>
                        <td>{{user_fullname}}</td>
                        <td>{{email}}</td>
                        <td>{{course}}</td>
                        <td>{{group}}</td>
                        <td>{{progress}}</td>
                        <td>{{grade}}</td>
                        <td class="gimidashboard-cert">
                            {{#certificate_yes}}<span class="gimidashboard-ok">✔</span>{{/certificate_yes}}
                            {{#certificate_no}}<span class="gimidashboard-no">✖</span>{{/certificate_no}}
                        </td>
                    </tr>
                {{/rows}}

                {{^rows}}
                    <tr>
                        <td colspan="7" class="gimidashboard-empty-row">No users found in this cohort.</td>
                    </tr>
                {{/rows}}
                </tbody>
            </table>
        </div>
    </div>
{{/cohorts}}

