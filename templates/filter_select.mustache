{{!
    @template local_gimidashboard/filter_select

    Example context (json):
    {
        "groups": [
            {
                "label": "Categories",
                "options": [
                    {
                        "value": "analytics",
                        "text": "Analytics",
                        "selected": false
                    },
                    {
                        "value": "reports",
                        "text": "Reports",
                        "selected": true
                    }
                ]
            },
            {
                "label": "Courses",
                "options": [
                    {
                        "value": "course-101",
                        "text": "Course 101",
                        "selected": false
                    },
                    {
                        "value": "course-202",
                        "text": "Course 202",
                        "selected": false
                    }
                ]
            }
        ]
    }
}}

<form class="gimidashboard-filter" method="get" action="">
    <label class="gimidashboard-filter-label" for="course">Category or course</label>

    <select name="course" id="course" class="gimidashboard-select">
        <option value="">Choose...</option>

        {{#groups}}
            <optgroup label="{{label}}">
                {{#options}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{{text}}}</option>
                {{/options}}
            </optgroup>
        {{/groups}}
    </select>
</form>
